# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# frontend dependencies
/frontend/node_modules
/frontend/.pnp
/frontend/.pnp.*
/frontend/.yarn/*
!/frontend/.yarn/patches
!/frontend/.yarn/plugins
!/frontend/.yarn/releases
!/frontend/.yarn/versions

# frontend testing
/frontend/coverage

# frontend next.js
/frontend/.next/
/frontend/out/

# frontend production
/frontend/build

# backend dependencies & build
/backend/node_modules
/backend/coverage
/backend/build
/backend/.pytest_cache
/backend/.mypy_cache
/backend/.ruff_cache
/backend/.hypothesis
/backend/.venv
/backend/*.db
/backend/*.sqlite3

# python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
dist/
site/
.eggs/
*.egg-info/
pip-wheel-metadata/
.venv/
venv/
env/
ENV/

# misc
.DS_Store
*.pem
*.log
*.sqlite3
*.db

# local editor / tooling files
.idea/
.vscode/
.cache/
.pre-commit-config.yaml

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (at root and subfolders)
.env
.env*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# typescript
*.tsbuildinfo
/frontend/next-env.d.ts
