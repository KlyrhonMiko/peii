PROJECT_NAME=peii-backend
PROJECT_VERSION=0.1.0
API_V1_PREFIX=/api/v1

DEBUG=true
SQL_ECHO=false
LOG_JSON=false


DB_MODE=local

LOCAL_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/peii
POSTGRES_DB=peii
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ADMINER_DEFAULT_SERVER=postgres

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URL=postgresql+psycopg2://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

BACKEND_CORS_ORIGINS=["http://localhost:3000"]


NEXT_TELEMETRY_DISABLED=1

